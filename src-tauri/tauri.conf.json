{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/tray-icon.png",
      "icons/tray-icon@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": null
    }
  },
  "productName": "PasswordCat",
  "version": "1.1.8",
  "identifier": "com.passwordcat.app",
  "plugins": {
    "shell": {
      "open": "",
      "scope": []
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'none'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "PasswordCat",
        "width": 1200,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 800,
        "visible": true,
        "skipTaskbar": false
      }
    ]
  }
}
